# ────────────────────────────────────────────────────────────
# CaptureNest Server Environment Variables
# Copy this to .env and customise for your environment.
# ────────────────────────────────────────────────────────────

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (SQLite)
DB_PATH=./capturenest.db

# Media storage
MEDIA_PATH=./media

# Ollama (local AI)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# Qdrant (vector DB)
QDRANT_URL=http://localhost:6333

# CORS
CORS_ORIGIN=http://localhost:3000

# Max upload file size (bytes, default 500MB)
MAX_FILE_SIZE=524288000

# Optional: override ffmpeg path
# FFMPEG_PATH=/usr/bin/ffmpeg

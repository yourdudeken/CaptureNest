{
  "name": "capturenest",
  "version": "1.4.0",
  "description": "AI-powered self-hosted camera and media capture server",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\" --names \"api,client\" --prefix-colors \"cyan,magenta\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "test": "echo \"No tests specified yet\" && exit 0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}